# Google OAuth / Auth.js
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_SECRET=generate-with-openssl-rand-base64-32
ALLOWED_EMAILS=you@uni.edu,colleague@uni.edu

# Groq model provider
GROQ_API_KEY=your-groq-api-key

# Existing autOScan engine on Fly.io
ENGINE_URL=https://your-engine-app.fly.dev
ENGINE_SECRET=your-shared-engine-secret

# Cloudflare R2 storage
# These can use the same bucket/secrets as autOScan-engine.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_APP_PREFIX=web
